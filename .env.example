# Cornerstone Insurance Portal Environment Configuration
PORT=8000

# Set your Gemini API key to enable high-speed cloud-based AI analysis and concierge chat.
# Get a free key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
ADMIN_PASSCODE=00000000

# SMTP Configuration for Real Email Validation (delivered to real inboxes)
# Set these parameters to enable direct delivery to real client email addresses.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM="Cornerstone Insurance Firm" <info@chatcif.com>

